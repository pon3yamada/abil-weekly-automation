# コピーして .env にリネームし、値を埋める（.env は Git に含めない）

# Shopify Admin API（fetch_shopify.py）
# ストア: mystore.myshopify.com（https なしで可）
# SHOPIFY_STORE=
# SHOPIFY_ACCESS_TOKEN=
# 任意: Admin API バージョン（未設定時は 2025-01）
# SHOPIFY_API_VERSION=

# Meta Marketing API
# META_ACCESS_TOKEN=
# META_AD_ACCOUNT_ID=

# Google Ads API（OAuth または開発者トークン方式に合わせて追加）
# GOOGLE_ADS_DEVELOPER_TOKEN=
# GOOGLE_ADS_CLIENT_ID=
# GOOGLE_ADS_CLIENT_SECRET=
# GOOGLE_ADS_REFRESH_TOKEN=
# GOOGLE_ADS_CUSTOMER_ID=

# Google Sheets（append_to_sheets.py）— CI では Repository secrets 参照
# GOOGLE_SHEETS_SPREADSHEET_ID=
# ローカル: JSON ファイルパス または 下記のどちらか一方
# GOOGLE_SHEETS_CREDENTIALS_FILE=
# GOOGLE_SHEETS_CREDENTIALS=
# 任意: シート名（デフォルト 週次データ）
# GOOGLE_SHEETS_SHEET_NAME=

# Claude API（改善アクション生成）
# ANTHROPIC_API_KEY=

# Slack Incoming Webhook
# SLACK_WEBHOOK_URL=

# surge.sh（CLI デプロイ時）
# SURGE_LOGIN=
# または CI ではトークン方式にする場合は別名で
