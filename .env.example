# コピーして .env にリネームし、値を埋める（.env は Git に含めない）

# Shopify Admin API
# SHOPIFY_STORE=
# SHOPIFY_ACCESS_TOKEN=

# Meta Marketing API
# META_ACCESS_TOKEN=
# META_AD_ACCOUNT_ID=

# Google Ads API（OAuth または開発者トークン方式に合わせて追加）
# GOOGLE_ADS_DEVELOPER_TOKEN=
# GOOGLE_ADS_CLIENT_ID=
# GOOGLE_ADS_CLIENT_SECRET=
# GOOGLE_ADS_REFRESH_TOKEN=
# GOOGLE_ADS_CUSTOMER_ID=

# Claude API（改善アクション生成）
# ANTHROPIC_API_KEY=

# Slack Incoming Webhook
# SLACK_WEBHOOK_URL=

# surge.sh（CLI デプロイ時）
# SURGE_LOGIN=
# または CI ではトークン方式にする場合は別名で
