<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow, noarchive, nosnippet, noimageindex">
  <title>ABiL 週次レポート一覧</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='%23DB4F2E'/><text x='50' y='68' font-size='52' text-anchor='middle' fill='white' font-family='sans-serif' font-weight='bold'>A</text></svg>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: {
              orange: '#DB4F2E',
              'orange-light': '#F26B4A',
              'orange-pale': '#FEF0EC',
              navy: '#19448e',
              'navy-light': '#2255A8',
              'navy-pale': '#EBF0F9',
            }
          },
          fontFamily: {
            sans: ['"Noto Sans JP"', '"Hiragino Sans"', '"Yu Gothic UI"', 'sans-serif'],
          }
        }
      }
    }
  </script>
</head>
<body class="bg-gray-50 min-h-screen font-sans">

  <!-- Header -->
  <header class="bg-white border-b border-gray-100 sticky top-0 z-40 shadow-sm">
    <div class="max-w-3xl mx-auto px-4 py-4 flex items-center gap-3">
      <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style="background:#DB4F2E">
        <span class="text-white font-black text-base">A</span>
      </div>
      <div>
        <h1 class="text-base font-bold text-gray-800 leading-tight">ABiL 週次レポート</h1>
        <p class="text-xs text-gray-400">ABIL.SHOP 週次データ履歴</p>
      </div>
    </div>
  </header>

  <!-- Main -->
  <main class="max-w-3xl mx-auto px-4 py-8">

    {% if reports %}
    <div class="space-y-3">
      {% for r in reports %}
      <a href="/{{ r.slug }}/"
         class="block bg-white rounded-xl border border-gray-100 shadow-sm hover:shadow-md hover:border-brand-orange/30 transition-all p-5 group">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-xs font-medium text-brand-orange mb-1">週次レポート</p>
            <p class="text-base font-bold text-gray-800 group-hover:text-brand-orange transition-colors">
              {{ r.period }}
            </p>
            <p class="text-xs text-gray-400 mt-1">生成日時: {{ r.generated_at }}</p>
          </div>
          <div class="text-gray-300 group-hover:text-brand-orange transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </div>
        </div>
      </a>
      {% endfor %}
    </div>
    {% else %}
    <div class="text-center py-20 text-gray-400">
      <p class="text-4xl mb-4">📋</p>
      <p class="font-medium">まだレポートがありません</p>
      <p class="text-sm mt-1">GitHub Actions が初回実行されると自動で追加されます</p>
    </div>
    {% endif %}

  </main>

  <footer class="text-center text-xs text-gray-300 py-8">
    ABiL Weekly Report • 自動生成
  </footer>

  <!-- Password Gate -->
  <div id="pw-gate" class="fixed inset-0 z-50 flex items-center justify-center bg-gray-900/80 backdrop-blur-sm">
    <div class="bg-white rounded-2xl shadow-2xl p-8 w-full max-w-sm mx-4">
      <div class="text-center mb-6">
        <div class="w-12 h-12 rounded-xl flex items-center justify-center mx-auto mb-3" style="background:#DB4F2E">
          <span class="text-white font-bold text-xl">A</span>
        </div>
        <h2 class="text-xl font-bold text-gray-800">ABiL 週次レポート</h2>
        <p class="text-sm text-gray-500 mt-1">パスワードを入力してください</p>
      </div>
      <div class="space-y-3">
        <input id="pw-input" type="password" placeholder="パスワード"
          class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:border-transparent"
          autocomplete="current-password">
        <p id="pw-error" class="text-red-500 text-sm text-center hidden">パスワードが違います</p>
        <button id="pw-btn" class="w-full text-white rounded-lg px-4 py-3 text-sm font-bold transition-colors"
          style="background:#DB4F2E">ログイン</button>
      </div>
    </div>
  </div>
  <script>
    (function () {
      const HASH = '{{ password_hash }}';
      const KEY = 'abil_report_auth';
      const gate = document.getElementById('pw-gate');
      if (sessionStorage.getItem(KEY) === HASH) { gate.remove(); return; }
      async function sha256(s) {
        const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(s));
        return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2, '0')).join('');
      }
      async function tryLogin() {
        const pw = document.getElementById('pw-input').value;
        const h = await sha256(pw);
        if (h === HASH) { sessionStorage.setItem(KEY, HASH); gate.remove(); }
        else { document.getElementById('pw-error').classList.remove('hidden'); document.getElementById('pw-input').value = ''; }
      }
      document.getElementById('pw-btn').addEventListener('click', tryLogin);
      document.getElementById('pw-input').addEventListener('keydown', e => { if (e.key === 'Enter') tryLogin(); });
    })();
  </script>
</body>
</html>
